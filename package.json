{
  "name": "crystal-nexus",
  "version": "0.1.0",
  "private": true,
  "description": "CRYSTAL NEXUS — next-generation 3D puzzle adventure",
  "workspaces": [
    "packages/*",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev -w client",
    "dev:server": "npm run start:dev -w server",
    "dev:all": "concurrently \"npm run dev -w client\" \"npm run start:dev -w server\"",
    "build": "npm run build -w packages/shared && npm run build -w client && npm run build -w server",
    "build:client": "npm run build -w client",
    "build:server": "npm run build -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
